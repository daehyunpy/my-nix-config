{
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^git\\s+status(\\s|$)"
            },
            {
              "pattern": "^git\\s+add(\\s|$)"
            }
          ]
        }
      }
    },
    "default_model": {
      "enable_thinking": true,
      "model": "gemini-3.1-pro-preview",
      "provider": "google",
    },
  },
  "autosave": "on_focus_change",
  "edit_predictions": {
    "provider": "zed",
  },
  "format_on_save": "on",
  "git_panel": {
    "tree_view": true,
  },
  "helix_mode": true,
  "inlay_hints": {
    "enabled": true,
  },
  "languages": {
    "Python": {
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
        "source.organizeImports.ruff": true,
      },
    },
    "SQL": {
      "tab_size": 2,
    },
  },
  "relative_line_numbers": "enabled",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "dark": "One Dark",
    "light": "One Light",
    "mode": "system",
  },
  "wrap_guides": [72, 79],
}
